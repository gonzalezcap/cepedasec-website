# Copy this to .env.local and fill in with actual values

# EmailJS Configuration
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=your_ga_id_here

# Instagram API (optional, for live feed)
NEXT_PUBLIC_INSTAGRAM_TOKEN=your_instagram_token_here

# Google Maps API Key (optional, for venue location)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_key_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://cepedasec.com
NEXT_PUBLIC_CONTACT_EMAIL=info@cepedasec.com
NEXT_PUBLIC_CONTACT_PHONE=918-830-3692
